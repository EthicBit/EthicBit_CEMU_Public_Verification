{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EthicBit Reason Registry Schema",
  "description": "Official schema for reason_registry*.json (v2.1 aligned with metadata root fields)",
  "type": "object",
  "required": [
    "$schema",
    "registry_version",
    "sector",
    "description",
    "rules"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "registry_version": {
      "type": "string"
    },
    "sector": {
      "type": "string",
      "enum": [
        "CORE",
        "JUSTICIA",
        "FINANZAS",
        "REGULATORY",
        "LEGAL",
        "TECHNICAL",
        "SECURITY"
      ],
      "description": "Sector to which the rules belong"
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "description",
          "category",
          "version",
          "severity",
          "reference",
          "justification",
          "evidence_sources"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "pattern": "^RULE-ETHIC-[A-Z0-9-]+-v[0-9]+\\.[0-9]+$"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "category": {
            "type": "string",
            "enum": [
              "TRACEABILITY",
              "ETHIC",
              "GOVERNANCE",
              "REPRODUCIBILITY",
              "SECURITY",
              "CLOSURE",
              "INTEGRITY",
              "EXPLAINABILITY",
              "TRANSPARENCY",
              "FAIRNESS",
              "DUE_PROCESS"
            ]
          },
          "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+$"
          },
          "severity": {
            "type": "string",
            "enum": [
              "CRITICAL",
              "HIGH",
              "MEDIUM"
            ]
          },
          "reference": {
            "type": "string",
            "minLength": 3
          },
          "justification": {
            "type": "string",
            "minLength": 15
          },
          "evidence_sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}