{
  "schema_id": "ethicbit.external_source_degradation_policy.v1",
  "policy": "MULTI_SOURCE_L5_DEGRADATION_HANDLING",
  "status": "ACTIVE",
  "minimum_sources_for_l4": 4,
  "current_sources_count": 5,
  "recognized_sources": [
    "arweave_external",
    "chainlink_external",
    "pyth_external",
    "real_local",
    "sepolia_external"
  ],
  "degradation_policy": {
