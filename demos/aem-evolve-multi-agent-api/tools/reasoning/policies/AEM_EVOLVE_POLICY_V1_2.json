{
  "schema_id": "AEM_EVOLVE_POLICY_V1_2",
  "version": "1.2.0",
  "effective_date": "2026-05-09",
  "policy_type": "mechanical_governance_policy",
  "enforcement": "DETERMINISTIC",
  "description": "Policy-as-code for MECH-REASON deterministic governance engine. All rules are evaluated mechanically. No LLM involvement in rule evaluation.",

  "claim_boundary_rules": [
    {
      "rule_id": "R-CLAIM-001",
      "field": "regulatory_approval_claimed",
      "operator": "eq",
      "value": true,
      "outcome": "FAIL_CLOSED",
      "severity": "CRITICAL",
      "explanation": "Regulatory approval cannot be claimed without a named regulator decision."
    },
    {
      "rule_id": "R-CLAIM-002",
      "field": "legal_compliance_claimed",
      "operator": "eq",
      "value": true,
      "outcome": "FAIL_CLOSED",
      "severity": "CRITICAL",
      "explanation": "Legal compliance cannot be claimed without admitted counsel opinion."
    },
    {
      "rule_id": "R-CLAIM-003",
      "field": "external_certification_claimed",
      "operator": "eq",
      "value": true,
      "outcome": "FAIL_CLOSED",
      "severity": "CRITICAL",
      "explanation": "External certification cannot be claimed without named certification body certificate."
    },
    {
      "rule_id": "R-CLAIM-004",
      "field": "production_readiness_claimed",
      "operator": "eq",
      "value": true,
      "outcome": "FAIL_CLOSED",
      "severity": "CRITICAL",
      "explanation": "Production readiness cannot be claimed without declared production evidence."
    },
    {
      "rule_id": "R-CLAIM-005",
      "field": "cybersecurity_certification_claimed",
      "operator": "eq",
      "value": true,
      "outcome": "FAIL_CLOSED",
      "severity": "CRITICAL",
      "explanation": "Cybersecurity certification cannot be claimed without named certification body."
    },
    {
      "rule_id": "R-CLAIM-006",
      "field": "financial_advice_claimed",
      "operator": "eq",
      "value": true,
      "outcome": "FAIL_CLOSED",
      "severity": "CRITICAL",
      "explanation": "Financial advice cannot be claimed by this system."
    },
    {
      "rule_id": "R-CLAIM-007",
      "field": "clinical_or_diagnostic_claimed",
      "operator": "eq",
      "value": true,
      "outcome": "FAIL_CLOSED",
      "severity": "CRITICAL",
      "explanation": "Clinical or diagnostic use cannot be claimed without medical device regulatory clearance."
    },
    {
      "rule_id": "R-CLAIM-008",
      "field": "tamper_proof_claimed",
      "operator": "eq",
      "value": true,
      "outcome": "FAIL_CLOSED",
      "severity": "CRITICAL",
      "explanation": "Tamper-proof cannot be claimed without independent security audit."
    },
    {
      "rule_id": "R-CLAIM-009",
      "field": "hsm_backed_claimed",
      "operator": "eq",
      "value": true,
      "outcome": "FAIL_CLOSED",
      "severity": "CRITICAL",
      "explanation": "HSM-backed cannot be claimed without HSM vendor attestation."
    },
    {
      "rule_id": "R-CLAIM-010",
      "field": "independent_reproduction_claimed",
      "operator": "eq",
      "value": true,
      "outcome": "FAIL_CLOSED",
      "severity": "CRITICAL",
      "explanation": "Independent reproduction cannot be claimed without external reproduction report."
    }
  ],

  "hitl_rules": [
    {
      "rule_id": "R-HITL-001",
      "condition": "governance_risk_score > 0.70",
      "outcome": "ESCALATE_TO_HITL",
      "explanation": "High governance risk requires human review before proceeding."
    },
    {
      "rule_id": "R-HITL-002",
      "condition": "evidence_completeness_score < 0.50",
      "outcome": "ESCALATE_TO_HITL",
      "explanation": "Insufficient evidence completeness requires human review."
    },
    {
      "rule_id": "R-HITL-003",
      "condition": "domain in [financial_cyber_risk, clinical, legal]",
      "outcome": "ESCALATE_TO_HITL",
      "explanation": "High-sensitivity domain requires mandatory human review."
    },
    {
      "rule_id": "R-HITL-004",
      "condition": "claim_boundary_risk_score > 0.60",
      "outcome": "ESCALATE_TO_HITL",
      "explanation": "Elevated claim boundary risk requires human review."
    }
  ],

  "scope_rules": [
    {
      "rule_id": "R-SCOPE-001",
      "condition": "evidence_completeness_score >= 0.50 AND evidence_completeness_score < 0.80",
      "outcome": "SCOPE_LIMITED",
      "explanation": "Partial evidence completeness limits the scope of the outcome."
    },
    {
      "rule_id": "R-SCOPE-002",
      "condition": "governance_risk_score >= 0.40 AND governance_risk_score <= 0.70",
      "outcome": "SCOPE_LIMITED",
      "explanation": "Moderate governance risk limits the scope of the outcome."
    },
    {
      "rule_id": "R-SCOPE-003",
      "condition": "anchor_integrity_score < 0.80",
      "outcome": "SCOPE_LIMITED",
      "explanation": "Partial anchor integrity limits the outcome to declared scope only."
    }
  ],

  "pass_conditions": {
    "description": "All of the following must be true for a PASS outcome",
    "conditions": [
      "no R-CLAIM-* rules triggered",
      "no R-HITL-* rules triggered",
      "evidence_completeness_score >= 0.80",
      "governance_risk_score <= 0.40",
      "anchor_integrity_score >= 0.80",
      "receipt_integrity_score >= 0.80",
      "regulatory_mapping_presence_score >= 0.50"
    ]
  },

  "decision_priority": [
    "FAIL_CLOSED",
    "ESCALATE_TO_HITL",
    "SCOPE_LIMITED",
    "PASS"
  ],

  "non_claims": [
    "This policy does not constitute regulatory approval.",
    "This policy does not constitute legal compliance.",
    "This policy is not externally certified.",
    "LLM output is not a policy rule.",
    "LLM output does not override mechanical gate decisions."
  ]
}
