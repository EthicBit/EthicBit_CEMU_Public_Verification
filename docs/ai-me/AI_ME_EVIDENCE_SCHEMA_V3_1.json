{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ethicbit.io/schemas/ai-me/evidence/v3.1",
  "title": "AI-ME Evidence Record v3.1",
  "description": "Evidence record schema for AEM-EVOLVE AI-ME Gate Suite v3.1. Subordinate to EthicBit / CEMU v3.7.0+. Specification Release only.",
  "type": "object",
  "required": [
    "schema_version",
    "gate_id",
    "gate_name",
    "evaluation_timestamp",
    "constitutional_dependency",
    "artifact_assurance_required",
    "artifact_assurance_status",
    "artifact_assurance",
    "gate_outcome",
    "claim_boundary_result",
    "fast_path",
    "allowed_claim",
    "non_claim"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "3.1",
      "description": "AI-ME evidence schema version"
    },
    "gate_id": {
      "type": "string",
      "pattern": "^AI-ME-[0-9]{2}$",
      "description": "Gate identifier, e.g. AI-ME-01"
    },
    "gate_name": {
      "type": "string",
      "description": "Human-readable gate name"
    },
    "evaluation_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of gate evaluation"
    },
    "evaluator_id": {
      "type": "string",
      "description": "Identifier of the evaluator or evaluation system"
    },
    "target": {
      "type": "string",
      "description": "Evaluation target identifier"
    },
    "scope": {
      "type": "string",
      "description": "Declared evaluation scope"
    },
    "constitutional_dependency": {
      "type": "string",
      "const": "EthicBit/CEMU/v3.7.0+",
      "description": "Constitutional dependency declaration"
    },
    "artifact_assurance_required": {
      "type": "boolean",
      "description": "Whether AEM v1.1 artifact assurance is required for this gate evaluation"
    },
    "artifact_assurance_status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "PENDING", "NOT_APPLICABLE"],
      "description": "AEM v1.1 artifact assurance status"
    },
    "artifact_assurance": {
      "type": "object",
      "required": [
        "aem_version",
        "artifact_verified",
        "artifact_manifest",
        "artifact_hashes",
        "verification_receipts",
        "public_anchor_references"
      ],
      "properties": {
        "aem_version": {
          "type": "string",
          "const": "v1.1",
          "description": "AEM version used for artifact assurance"
        },
        "artifact_verified": {
          "type": "boolean",
          "description": "Whether the evidence artifact was verified by AEM v1.1"
        },
        "artifact_manifest": {
          "type": "string",
          "description": "Path or identifier of the AEM v1.1 manifest used for verification"
        },
        "artifact_hashes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["artifact_id", "algorithm", "hash"],
            "properties": {
              "artifact_id": {"type": "string"},
              "algorithm": {"type": "string", "enum": ["sha256", "sha512"]},
              "hash": {"type": "string"}
            }
          },
          "description": "Hash records for verified artifacts"
        },
        "verification_receipts": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Paths or identifiers of AEM v1.1 verification receipts"
        },
        "public_anchor_references": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Public anchor references where artifacts have been anchored via Triple Anchor"
        }
      }
    },
    "evidence_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "artifact_type", "artifact_path"],
        "properties": {
          "artifact_id": {"type": "string"},
          "artifact_type": {
            "type": "string",
            "enum": [
              "model_evaluation_report",
              "fairness_report",
              "explainability_artifact",
              "data_lineage_graph",
              "agent_trace_report",
              "tool_call_log",
              "memory_mutation_record",
              "hitl_decision_record",
              "multi_agent_coordination_log",
              "red_team_report",
              "decision_log",
              "claim_boundary_enforcement_log",
              "canonical_snapshot",
              "fast_path_snapshot_reference",
              "verification_receipt",
              "anchor_receipt",
              "execution_manifest",
              "evidence_package"
            ]
          },
          "artifact_path": {"type": "string"},
          "artifact_hash": {"type": "string"},
          "artifact_verified": {"type": "boolean"}
        }
      }
    },
    "gate_outcome": {
      "type": "string",
      "enum": [
        "PASS",
        "SCOPE_LIMITED",
        "FAIL_CLOSED",
        "NOT_APPLICABLE_WITH_JUSTIFICATION",
        "MISSING",
        "PENDING_EXTERNAL_REVIEW"
      ],
      "description": "Gate evaluation outcome"
    },
    "gate_outcome_reason": {
      "type": "string",
      "description": "Reason for the gate outcome, especially for non-PASS outcomes"
    },
    "claim_boundary_result": {
      "type": "object",
      "required": ["claim_class", "claim_level_ceiling", "allowed_emission"],
      "properties": {
        "claim_class": {
          "type": "string",
          "enum": ["FULL_CLAIM", "SCOPED_CLAIM", "PENDING_CLAIM", "UNSUPPORTED_CLAIM", "PROHIBITED_CLAIM"]
        },
        "claim_level_ceiling": {
          "type": "string",
          "enum": ["PASS", "SCOPE_LIMITED", "FAIL_CLOSED", "PENDING_EXTERNAL_REVIEW", "NOT_APPLICABLE"]
        },
        "allowed_emission": {
          "type": "boolean",
          "description": "Whether a claim emission is allowed at or below the ceiling"
        },
        "scope_qualifier": {
          "type": "string",
          "description": "Required scope qualifier for SCOPED_CLAIM emissions"
        }
      }
    },
    "fast_path": {
      "type": "object",
      "required": [
        "enabled",
        "snapshot_reference",
        "snapshot_freshness_ms",
        "pre_execution_verdict",
        "max_tick_elapsed_ms",
        "full_assurance_recalculated_per_tick",
        "fast_path_scope"
      ],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether Fast Path enforcement is enabled for this gate"
        },
        "snapshot_reference": {
          "type": "string",
          "description": "Reference to the signed canonical snapshot used by Fast Path"
        },
        "snapshot_freshness_ms": {
          "type": ["integer", "null"],
          "description": "Age of the snapshot in milliseconds at time of evaluation"
        },
        "pre_execution_verdict": {
          "type": "string",
          "enum": ["PASS", "BLOCK", "SCOPE_LIMITED", "DEGRADED", "NOT_VERIFIABLE", "FAIL_CLOSED", "NOT_APPLICABLE"],
          "description": "Fast Path pre-execution verdict"
        },
        "max_tick_elapsed_ms": {
          "type": ["integer", "null"],
          "description": "Maximum allowed tick elapsed time for Fast Path enforcement in milliseconds"
        },
        "full_assurance_recalculated_per_tick": {
          "type": "boolean",
          "const": false,
          "description": "Fast Path does not recalculate full Triple Anchor, Strong Closure, or complete AI-ME evidence per tick. Always false."
        },
        "fast_path_scope": {
          "type": "string",
          "description": "Declared scope of Fast Path enforcement for this gate"
        }
      }
    },
    "allowed_claim": {
      "type": "string",
      "description": "The allowed claim statement for this gate evaluation, bounded to verified evidence"
    },
    "non_claim": {
      "type": "string",
      "description": "The non-claim statement declaring what this gate evaluation does not claim"
    },
    "high_risk_output": {
      "type": "boolean",
      "description": "Whether this gate evaluation applies to a high-risk output category"
    },
    "high_risk_category": {
      "type": "string",
      "enum": [
        "financial_decision_support",
        "cybersecurity_response",
        "regulatory_compliance",
        "clinical_medical_support",
        "public_sector_decision",
        "identity_access_eligibility",
        "legal_quasi_legal",
        "not_applicable"
      ]
    },
    "hitl_required": {
      "type": "boolean",
      "description": "Whether AI-ME-08 HITL review is required for this evaluation"
    },
    "hitl_artifact_reference": {
      "type": "string",
      "description": "Reference to the HITL decision artifact (if applicable)"
    }
  }
}
