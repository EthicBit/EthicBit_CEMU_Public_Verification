ds on both a faulty signature generated by a vulnerable version of Elliptic and a correct signature for the same inputs.\n\nThis issue affects all known versions of Elliptic (at the time of writing, versions less than or equal to 6.6.1).","cvss":[{"source":"36c7be3b-2937-45df-85ea-ca7133ea542c","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L","metrics":{"baseScore":5.6,"exploitabilityScore":2.3,"impactScore":3.4},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-14505","epss":0.00011,"percentile":0.0144,"date":"2026-04-11"}],"cwes":[{"cve":"CVE-2025-14505","cwe":"CWE-1240","source":"36c7be3b-2937-45df-85ea-ca7133ea542c","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"elliptic","version":"6.6.1"}},"found":{"vulnerabilityID":"GHSA-848j-6mx2-7j84","versionConstraint":"<=6.6.1 (semantic)"}}],"artifact":{"id":"5c9f1670cb407ffe","name":"elliptic","version":"6.6.1","type":"npm","locations":[{"path":"/package-lock.json","accessPath":"/package-lock.json","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":["MIT"],"cpes":["cpe:2.3:a:indutny:elliptic:6.6.1:*:*:*:*:node.js:*:*"],"purl":"pkg:npm/elliptic@6.6.1","upstreams":[]}},{"vulnerability":{"id":"GHSA-3qwc-47jf-5rf7","dataSource":"https://github.com/advisories/GHSA-3qwc-47jf-5rf7","namespace":"github:language:python","severity":"Medium","urls":["https://github.com/ethereum/eth-abi/security/advisories/GHSA-3qwc-47jf-5rf7","https://github.com/ethereum/eth-abi/commit/82c1ad37a866472562d81fedaef0f4fed0a08269"],"description":"eth-abi is vulnerable to recursive DoS","cvss":[],"fix":{"versions":["5.0.1"],"state":"fixed","available":[{"version":"5.0.1","date":"2024-03-05","kind":"first-observed"}]},"advisories":[],"risk":0},"relatedVulnerabilities":[],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","se